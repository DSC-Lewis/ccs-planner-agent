# Copy to .env for local dev.
CCS_HOST=0.0.0.0
CCS_PORT=8000
CCS_STORAGE_PATH=./app/var/storage.json
# SQLite DB path (v4). Created on first boot; existing storage.json is
# imported once via storage.auto_migrate_legacy_if_empty().
CCS_DATABASE_PATH=./app/var/ccs.db

# ---- CORS ----
# Comma-separated allowlist. Use "*" only if credentials stay off.
CCS_CORS_ORIGINS=*
# true/false — when true + ORIGINS=* the app refuses to start (safety fuse).
CCS_CORS_CREDENTIALS=false

# ---- Auth / users (v4) ----
# Admin bootstrap: when set, an 'admin' user is created on boot with this
# key. Use it as the X-API-Key for admin calls (including POST /api/users
# to mint keys for other users).
CCS_ADMIN_KEY=
# Legacy alias — if CCS_ADMIN_KEY is unset, CCS_API_KEY is used in its place.
CCS_API_KEY=

# ---- Rate limit ----
# N/SECONDS. Default is 30 requests per minute per IP.
CCS_RATE_LIMIT=30/60

# ---- Retention ----
# Sessions older than this (seconds) are purged on the next write. 7 days.
CCS_SESSION_TTL_SECONDS=604800
