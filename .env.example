# Copy to .env for local dev.
CCS_HOST=0.0.0.0
CCS_PORT=8000
CCS_STORAGE_PATH=./app/var/storage.json

# ---- CORS ----
# Comma-separated allowlist. Use "*" only if credentials stay off.
CCS_CORS_ORIGINS=*
# true/false — when true + ORIGINS=* the app refuses to start (safety fuse).
CCS_CORS_CREDENTIALS=false

# ---- Auth (optional) ----
# Set to a long random value to require X-API-Key on /api/* routes.
CCS_API_KEY=

# ---- Rate limit ----
# N/SECONDS. Default is 30 requests per minute per IP.
CCS_RATE_LIMIT=30/60

# ---- Retention ----
# Sessions older than this (seconds) are purged on the next write. 7 days.
CCS_SESSION_TTL_SECONDS=604800
